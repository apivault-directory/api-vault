# Your domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Plausible analytics (optional — analytics.plausible.io)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com
